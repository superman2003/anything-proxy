# Anything AI credentials
ACCESS_TOKEN=your_access_token_here
REFRESH_TOKEN=your_refresh_token_here
PROJECT_GROUP_ID=your_project_group_id_here

# Optional: API key to protect this proxy
# API_KEY=sk-your-api-key

# Server settings
HOST=0.0.0.0
PORT=3000

# Optional: PostgreSQL
# DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/anything_proxy
# DB_POOL_MIN_SIZE=1
# DB_POOL_MAX_SIZE=10
# AUTO_MIGRATE_SQLITE_TO_POSTGRES=true
# DB_SCHEMA=anything_proxy

# Optional: Redis
# REDIS_URL=redis://127.0.0.1:6379/0
# REDIS_PREFIX=anything_proxy

# Optional: HTTP proxy
# PROXY_URL=http://127.0.0.1:7890
